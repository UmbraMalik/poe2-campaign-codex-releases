{
  "compilerOptions": {
    "target": "ES2021",
    "module": "CommonJS",
    "moduleResolution": "Node",
    "lib": ["ES2021", "DOM"],
    "outDir": ".tmp-tests",
    "rootDir": ".",
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true
  },
  "include": [
    "src/main/**/*.ts",
    "src/shared/**/*.ts",
    "src/renderer/companion-helpers.ts",
    "tests/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".tmp-tests",
    "dist",
    "dist-electron",
    "release"
  ]
}
